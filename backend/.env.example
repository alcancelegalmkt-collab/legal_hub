# ========================================
# Legal Hub - Configuração Backend
# ========================================

# ===== Database =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legal_hub
DB_USER=postgres
DB_PASSWORD=your_password

# ===== JWT =====
JWT_SECRET=your_super_secret_jwt_key_change_this

# ===== API Configuration =====
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ===== Claude API (Document Generation) =====
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ===== ZapSign (Digital Signatures) =====
ZAPSIGN_API_KEY=your_zapsign_api_key

# ===== Trello (Task Management) =====
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token

# ===== Push Notifications (VAPID) - OBRIGATÓRIO PARA PWA =====
VAPID_PUBLIC_KEY=BOKXHaSaVr5PcTrSE7w9EF1bX9bVvc_dHB45XqOsUHJtlVHvDDNTlE2dQ6qx7bWShrqZQLTMBVRAYcbnJTetlBw
VAPID_PRIVATE_KEY=LVnaZhXeC8ex7tJNSIFqvFxlKdmMqOO16wv4QlkckOQ
VAPID_EMAIL=seu-email@example.com

# ===== Google Calendar (Optional) =====
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3000/api/case-progress/calendar/callback

# ===== Email Service (Optional) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Legal Hub <noreply@yourdomain.com>

# SendGrid Alternative
SENDGRID_API_KEY=SG.xxxx

# ===== Slack Webhooks (Notifications) =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-token

# ===== n8n Webhook URLs =====
N8N_WEBHOOK_URL=http://localhost:5678

# ===== Storage =====
UPLOAD_DIR=./uploads
DOCUMENTS_DIR=./uploads/documents

# ===== HTTPS (Production) =====
SECURE_COOKIE=false
NODE_TLS_REJECT_UNAUTHORIZED=0

# ===== Monitoring (Optional) =====
SENTRY_DSN=your-sentry-dsn
