{
  "name": "legal-hub-backend",
  "version": "1.0.0",
  "description": "Backend API for Legal Hub - Law Office Automation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all"
  },
  "keywords": [
    "legal",
    "crm",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.3.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "docx": "^8.5.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "form-data": "^4.0.0",
    "google-auth-library": "^9.4.1",
    "googleapis": "^118.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.10.0",
    "pg-hstore": "^2.3.4",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.6.11",
    "resend": "^6.12.0",
    "sequelize": "^6.35.0",
    "sqlite3": "^6.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.3.1",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
