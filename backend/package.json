{
  "name": "legal-hub-backend",
  "version": "1.0.0",
  "description": "Backend API for Legal Hub - Law Office Automation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all"
  },
  "keywords": ["legal", "crm", "automation"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.0",
    "pg": "^8.10.0",
    "pg-hstore": "^2.3.4",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.0",
    "redis": "^4.6.11",
    "axios": "^1.6.0",
    "docx": "^8.5.0",
    "pdf-lib": "^1.17.1",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "typescript": "^5.1.3",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1"
  }
}
